---
const base = import.meta.env.BASE_URL;
---

<section id="projects" class="max-w-7xl mx-auto px-6 py-28">
  <h2 class="text-4xl sm:text-5xl md:text-6xl font-bold mb-12 text-center">
  <span class="bg-clip-text text-transparent animated-gradient">
    Projects
  </span>
  <br><br>
</h2>

<style>
.animated-gradient {
  background-image: linear-gradient(270deg, #00b4d8, #90e0ef, #0077b6, #48cae4);
  background-size: 600% 600%;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  animation: gradientShift 4s ease infinite;
}

@keyframes gradientShift {
  0% { background-position: 0% 50%; }
  50% { background-position: 100% 50%; }
  100% { background-position: 0% 50%; }
}
</style>

  <div class="grid grid-cols-1 gap-10 md:grid-cols-2 lg:grid-cols-2">

    <a href="https://blisa.es" target="_blank" rel="noopener noreferrer"
       class="group block bg-white/5 backdrop-blur-md border border-white/10 rounded-xl overflow-hidden 
              hover:scale-[1.02] hover:border-blue-400/40 transition shadow-lg shadow-black/20">

      <div class="w-full h-64 sm:h-72 md:h-80 overflow-hidden bg-black/20 flex items-center justify-center">
        <img 
          src={`${base}/blisa.png`} 
          alt="Blisa" 
          class="max-w-full max-h-full object-contain"
        />
      </div>

      <div class="p-8">
        <h3 class="text-2xl sm:text-3xl font-semibold mb-3 group-hover:text-blue-400 transition">
          Blisa
        </h3>

        <p class="text-slate-400 text-base mb-5 max-w-2xl">
         Blisa.es is a web project I contributed to, helping improve and maintain the platform while supporting feature development and enhancing the overall user experience and performance.
        </p>

        <div class="flex flex-wrap gap-3 text-sm mb-4">
          <span class="bg-white/10 px-3 py-1 rounded">WordPress</span>
          <span class="bg-white/10 px-3 py-1 rounded">JavaScript</span>
          <span class="bg-white/10 px-3 py-1 rounded">PHP</span>
        </div>

        <span class="text-blue-400 text-base opacity-80 group-hover:opacity-100 inline-block">
          View project →
